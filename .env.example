# === Node ===
NODE_ID=ai-pi-02
CAMERA_LABEL=vision-pi-01
LOCATION_LABEL=거실
SCHEMA_VERSION=1.1
FPS_TARGET=10

# === ZMQ (vision-pi 수신) ===
# vision-pi의 IP로 교체: 예) tcp://192.168.0.10:5555
ZMQ_ENDPOINT=tcp://127.0.0.1:5555
ZMQ_TOPIC=pose
ZMQ_RECV_TIMEOUT_MS=1000

# === MQTT (로컬 브로커 발행) ===
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=edgesafe-ai-pi02
MQTT_TOPIC_FALL=edgesafe/ai/fall
MQTT_TOPIC_STATUS=edgesafe/ai/status
MQTT_KEEPALIVE_SEC=30
STATUS_INTERVAL_SEC=10

# === Rule Gate (Phase 2) ===
# 임계값을 환경별로 튜닝할 때만 설정. 미지정 시 src/config.py 기본값 사용.
# HIP_DROP_VELOCITY_THRESH=0.6
# TORSO_ANGLE_HORIZONTAL_DEG=55.0
# BBOX_ASPECT_RATIO_THRESH=1.1
# TORSO_VERTICAL_EXTENT_THRESH=0.12
# DESCENDING_TO_FALLEN_TIMEOUT_SEC=2.5
# FALLEN_CONFIRM_TIMEOUT_SEC=1.5
# FALLEN_EXIT_SUSTAIN_SEC=0.5
# STILLNESS_MOTION_THRESH=0.10
# FALL_COOLDOWN_SEC=5.0

# === CNN Validator (Phase 3) ===
# CNN_ENABLED=true                       # false면 모델 있어도 호출 X
# CNN_MODEL_PATH=models/fall_validator.tflite
# CNN_FUSION_WEIGHT=0.4                  # final = (1-w)*rule + w*cnn
# CNN_FALL_PROB_THRESH=0.5

# === Logging ===
LOG_LEVEL=INFO
