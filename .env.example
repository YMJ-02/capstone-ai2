# === Node ===
NODE_ID=ai-pi-02
CAMERA_LABEL=vision-pi-01
LOCATION_LABEL=거실
SCHEMA_VERSION=1.1
FPS_TARGET=10

# === ZMQ (vision-pi 수신) ===
# vision-pi의 IP로 교체: 예) tcp://192.168.0.10:5555
ZMQ_ENDPOINT=tcp://127.0.0.1:5555
ZMQ_TOPIC=pose
ZMQ_RECV_TIMEOUT_MS=1000

# === MQTT (로컬 브로커 발행) ===
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=edgesafe-ai-pi02
MQTT_TOPIC_FALL=edgesafe/ai/fall
MQTT_TOPIC_STATUS=edgesafe/ai/status
MQTT_KEEPALIVE_SEC=30
STATUS_INTERVAL_SEC=10

# === Logging ===
LOG_LEVEL=INFO
